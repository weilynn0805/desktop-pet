# 依赖（可由 npm install 还原，不入库）
node_modules/

# 运行期生成的本地配置（如宠物位置）
# 注意：electron 的 userData 配置在系统目录，不在本项目内，这里仅作占位说明
dist/
out/
测试安装包/

# 签名密钥与图标源（不入库：私钥/证书属敏感物，源图体积大）
build/*.pfx
build/icon-source.png
build/icon-source.png.png

# 日志
*.log
npm-debug.log*

# 系统/编辑器
.DS_Store
Thumbs.db
.vscode/
.idea/

# 测试素材：只保留生成的小测试动画，忽略用户自带的大视频/图片
测试素材/*
!测试素材/test-pet.gif
!测试素材/test-pet.png
